generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model favorite_routes {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  origin      String?   @db.VarChar(255)
  destination String?   @db.VarChar(255)
  alias       String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model pdf_reports {
  id           Int       @id @default(autoincrement())
  trip_id      Int?
  file_url     String
  date_created DateTime? @default(now()) @db.Timestamptz(6)
  trips        trips?    @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model trips {
  id               Int           @id @default(autoincrement())
  user_id          Int?
  origin           String?       @db.VarChar(255)
  destination      String?       @db.VarChar(255)
  distance_km      Decimal?      @db.Decimal(8, 2)
  fuel_consumption Decimal?      @db.Decimal(5, 2)
  fuel_price       Decimal?      @db.Decimal(6, 2)
  tolls            Decimal?      @db.Decimal(8, 2)
  passengers       Int?
  is_round_trip    Boolean?      @default(false)
  total_cost       Decimal?      @db.Decimal(10, 2)
  cost_per_person  Decimal?      @db.Decimal(10, 2)
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  pdf_reports      pdf_reports[]
  users            users?        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id           Int               @id @default(autoincrement())
  username     String            @unique(map: "unique_username") @db.VarChar(255)
  email        String            @unique(map: "unique_email") @db.VarChar(255)
  password     String            @db.VarChar(255)
  date_created DateTime?         @default(now()) @db.Timestamptz(6)
  favorite_routes favorite_routes[]
  trips       trips[]
}
